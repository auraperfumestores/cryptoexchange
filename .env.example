# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/crypto-exchange?retryWrites=true&w=majority

# NextAuth
NEXTAUTH_SECRET=replace-with-a-random-secret-min-32-chars
# NEXTAUTH_URL intentionally unset in dev — NextAuth auto-detects port.
# Set explicitly in production: https://yourdomain.com
NEXTAUTH_URL=http://localhost:3000

NEXT_PUBLIC_WC_PROJECT_ID=

# CoinGecko (optional, for base price auto-fetch)
COINGECKO_API_KEY=

# Vercel Blob (for payment proof & QR uploads)
BLOB_READ_WRITE_TOKEN=

# Admin seed
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=ChangeMe123!

# Public app URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email (Resend) — set RESEND_API_KEY to enable real email sending.
# In dev, verification links are logged to the console if unset.
# Get your key at: https://resend.com/api-keys
# EMAIL_FROM's domain (swappinr.com) must be a verified domain in Resend
# (Domains tab → add SPF/DKIM DNS records) before sending will succeed.
RESEND_API_KEY=
EMAIL_FROM=SwappINR <noreply@swappinr.com>

# ── SwappINR Vault contracts (deploy contracts/SwapINRVault.sol to each chain) ──
# After deployment paste the contract addresses below.
# NEXT_PUBLIC_* vars are safe to expose — they are just contract addresses.
NEXT_PUBLIC_VAULT_BEP20=
NEXT_PUBLIC_VAULT_ERC20=
NEXT_PUBLIC_VAULT_TRC20=

# Platform hot wallet that calls pullFunds() on the vault — keep SECRET, server-only.
# Fund this wallet with small amounts of BNB/ETH for gas fees only.
VAULT_BEP20=
VAULT_ERC20=
VAULT_TRC20=
VAULT_OPERATOR_PRIVATE_KEY=
TRON_OPERATOR_PRIVATE_KEY=

TRONGRID_API_KEY=

# ── Firebase (Phone OTP) ──
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Cashfree Verification Suite (UPI VPA penny-drop verification — real bank account holder name)
CASHFREE_CLIENT_ID=
CASHFREE_CLIENT_SECRET=
# Set to "production" to hit api.cashfree.com; anything else uses sandbox.cashfree.com
CASHFREE_ENV=sandbox

# ── Telegram Support Bot ──
# Bot token from @BotFather. Group must be a supergroup with "Topics" enabled,
# with the bot added as admin (needs: manage topics, post messages).
TELEGRAM_BOT_TOKEN=
# The group's chat ID (negative number, e.g. -1001234567890).
TELEGRAM_SUPPORT_GROUP_ID=
# Optional — set this to the same value passed to setWebhook so the webhook
# route can verify requests are really coming from Telegram.
TELEGRAM_WEBHOOK_SECRET=
# Optional — protects /api/cron/support-reminders from being called by anyone
# other than Vercel Cron (Vercel sends this automatically when set).
CRON_SECRET=
