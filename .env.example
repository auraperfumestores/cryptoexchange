# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/crypto-exchange?retryWrites=true&w=majority

# NextAuth
NEXTAUTH_SECRET=replace-with-a-random-secret-min-32-chars
NEXTAUTH_URL=http://localhost:3000

# CoinGecko (optional, for base price auto-fetch)
COINGECKO_API_KEY=

# Vercel Blob (for payment proof & QR uploads)
BLOB_READ_WRITE_TOKEN=

# Admin seed
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=ChangeMe123!

# Public app URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cloudflare Turnstile (bot protection on page load, login, register, OTP send)
# Create a Turnstile site at https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
