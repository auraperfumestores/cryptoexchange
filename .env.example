# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/crypto-exchange?retryWrites=true&w=majority

# NextAuth
NEXTAUTH_SECRET=replace-with-a-random-secret-min-32-chars
NEXTAUTH_URL=http://localhost:3000

# CoinGecko (optional, for base price auto-fetch)
COINGECKO_API_KEY=

# Vercel Blob (for payment proof & QR uploads)
BLOB_READ_WRITE_TOKEN=

# Admin seed
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=ChangeMe123!

# Public app URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Bot protection: handled at the edge via Cloudflare WAF (Managed Challenge rule
# on swappinr.com), not in application code. No env vars needed here.

# Cashfree Verification Suite (UPI VPA penny-drop verification — real bank account holder name)
CASHFREE_CLIENT_ID=
CASHFREE_CLIENT_SECRET=
# Set to "production" to hit api.cashfree.com; anything else uses sandbox.cashfree.com
CASHFREE_ENV=sandbox
